# Supabase
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase service role key — SERVER ONLY, never prefix with NEXT_PUBLIC_
# Found in: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# DeepSeek API — SERVER ONLY, never prefix with NEXT_PUBLIC_
# Found in: platform.deepseek.com → API Keys
DEEPSEEK_API_KEY=your-deepseek-api-key
